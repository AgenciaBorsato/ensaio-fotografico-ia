generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EnsaioStatus {
  draft
  training
  trained
  generating
  completed
}

enum TrainingStatus {
  pending
  processing
  completed
  failed
}

enum PhotoStatus {
  generating
  face_swapping
  upscaling
  restoring
  scoring
  pending_review
  approved
  rejected
}

model Ensaio {
  id          String       @id @default(cuid())
  name        String
  description String?
  status      EnsaioStatus @default(draft)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  inspirationPhotoUrl String?

  // Prompts para geracao (cada linha = 1 foto a gerar)
  prompts String[] @default([])
  // Quantidade de fotos a gerar por prompt
  photosPerPrompt Int @default(1)

  referencePhotos ReferencePhoto[]
  loraModel       LoraModel?
  generatedPhotos GeneratedPhoto[]
}

model ReferencePhoto {
  id       String @id @default(cuid())
  ensaioId String
  ensaio   Ensaio @relation(fields: [ensaioId], references: [id], onDelete: Cascade)
  photoUrl String
  order    Int

  createdAt DateTime @default(now())

  @@index([ensaioId])
}

model LoraModel {
  id                  String         @id @default(cuid())
  ensaioId            String         @unique
  ensaio              Ensaio         @relation(fields: [ensaioId], references: [id], onDelete: Cascade)
  replicateTrainingId String?
  status              TrainingStatus @default(pending)
  progress            Int            @default(0)
  loraUrl             String?
  triggerWord         String
  replicateModelUrl   String?
  trainingCostUsd     Float?
  errorMessage        String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model GeneratedPhoto {
  id       String      @id @default(cuid())
  ensaioId String
  ensaio   Ensaio      @relation(fields: [ensaioId], references: [id], onDelete: Cascade)

  prompt String // o prompt usado para gerar essa foto

  rawUrl      String?
  upscaledUrl String?
  restoredUrl String?

  similarityScore Float?
  attempt         Int         @default(1)
  maxAttempts     Int         @default(3)
  status          PhotoStatus @default(generating)
  seed            Int?

  notes                 String?
  replicatePredictionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ensaioId])
  @@index([status])
}
